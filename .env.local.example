# ---- Database ----
# Neon PostgreSQL (replace with your own from console.neon.tech)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ---- NextAuth ----
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-32-char-string"

# For local dev:
NEXTAUTH_URL="http://localhost:3000"
# For production (your Vercel URL):
# NEXTAUTH_URL="https://your-project.vercel.app"

# ---- Optional ----
# Points earned per RM spent (default: 1)
POINTS_PER_RM=1
